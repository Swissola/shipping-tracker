# shipping-tracker environment variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git — it is excluded by .gitignore

TRACKINGMORE_API_KEY=your_api_key_here
LOG_LEVEL=WARNING
LOG_PATH=logs/shipping-tracker.log

# Notification channel for status-change alerts is configured here in Phase 05.1
# (e.g. ntfy/Pushover/Telegram) — placeholder vars added when that phase is planned.

# Gmail integration (Phase 2)
GMAIL_TOKEN_PATH=token.json
GMAIL_CREDENTIALS_PATH=credentials.json
# GMAIL_SENDER_LIST: comma-separated sender domains/addresses (e.g. @aliexpress.com,ship@store.example.com)
GMAIL_SENDER_LIST=@aliexpress.com
# GMAIL_LOOKBACK_DAYS: integer; controls newer_than:Nd in the Gmail search query (default 30)
GMAIL_LOOKBACK_DAYS=30
